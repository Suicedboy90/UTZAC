rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) { return true; }
    function isValidChat(data) { return true; }
    function isValidMessage(data) { return true; }
    function isValidAnimal(data) { return true; }
    function isValidPotrero(data) { return true; }
    function isValidReproductionEvent(data) { return true; }
    function isValidProductionRecord(data) { return true; }
    function isValidFinanceTransaction(data) { return true; }
    function isValidAnimalTransfer(data) { return true; }
    function isValidInventoryItem(data) { return true; }
    function isValidTask(data) { return true; }
    function isValidMarketplaceOffer(data) { return true; }
    function isValidReview(data) { return true; }

    function isAnimalOwner(data) {
      return data.id_propietario == request.auth.uid || data.id_propietario == 'vendido_' + request.auth.uid;
    }

    // Animals
    match /animals/{animalId} {
      allow read, write: if isAuthenticated();
    }

    // Potreros
    match /potreros/{potreroId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidPotrero(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidPotrero(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Razas
    match /razas/{razaId} {
      allow read: if isAuthenticated();
      allow write: if false; // Read-only for users
    }

    // Fincas
    match /fincas/{fincaId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function isValidNotification(data) {
      return hasRequiredFields(['userId', 'title', 'message', 'date', 'read', 'type']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.read is bool &&
             data.type is string && data.type.size() < 50;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    // Helper for history migration
    function canMigrateHistory(data, newUserId) {
      // Allow migration if there is a completed or accepted transfer for this animal to this user
      // Supporting both 'animalId' and legacy 'id_animal' fields
      return (
        (('animalId' in data && data.animalId != null && 
          exists(/databases/$(database)/documents/animal_transfers/$(data.animalId + "_" + newUserId)) &&
          get(/databases/$(database)/documents/animal_transfers/$(data.animalId + "_" + newUserId)).data.status in ['accepted', 'completed'] &&
          (request.auth.uid == get(/databases/$(database)/documents/animal_transfers/$(data.animalId + "_" + newUserId)).data.sellerId ||
           request.auth.uid == get(/databases/$(database)/documents/animal_transfers/$(data.animalId + "_" + newUserId)).data.buyerId)
         ))
        ||
        (('id_animal' in data && data.id_animal != null && 
          exists(/databases/$(database)/documents/animal_transfers/$(data.id_animal + "_" + newUserId)) &&
          get(/databases/$(database)/documents/animal_transfers/$(data.id_animal + "_" + newUserId)).data.status in ['accepted', 'completed'] &&
          (request.auth.uid == get(/databases/$(database)/documents/animal_transfers/$(data.id_animal + "_" + newUserId)).data.sellerId ||
           request.auth.uid == get(/databases/$(database)/documents/animal_transfers/$(data.id_animal + "_" + newUserId)).data.buyerId)
         ))
      );
    }

    // Health Events
    match /health_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Feeding Records
    match /feeding_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Reproduction Events
    match /reproduction_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidReproductionEvent(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Production Records
    match /production_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidProductionRecord(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Finance Transactions
    match /finance_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFinanceTransaction(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User Profiles (Private)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Public Profiles (Safe fields only)
    match /public_profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants.hasAny([request.auth.uid]);
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) &&
        get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && 
        resource.data.senderId != request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        request.resource.data.read == true;
    }

    // Animal Transfers
    match /animal_transfers/{transferId} {
      allow read, write: if isAuthenticated();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidInventoryItem(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidInventoryItem(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || canMigrateHistory(resource.data, request.resource.data.userId));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Marketplace
    match /marketplace_offers/{offerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMarketplaceOffer(request.resource.data);
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid && isValidMarketplaceOffer(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if false; // Reviews are immutable for now
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
  }
}
